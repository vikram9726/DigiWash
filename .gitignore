# Secrets & environment
.env

# JSON files (except firebase SW and composer)
*.json
!firebase-messaging-sw.js
!composer.json

# Dependencies
vendor/
node_modules/

# OS & editor
.DS_Store
*.log
tmp/
.idea/
.vscode/

# Hostinger server-generated files
private/
google*.html
sitemap*.xml

# User uploads (server-side content, not tracked in git)
uploads/

# Composer lock — managed by Hostinger on deploy
composer.lock

# Debug & temp files — NEVER commit to production
temp_debug.php
temp_*.php
debug_*.php
*_test.php

# Repomix output (auto-generated, large, do not commit)
repomix-output.xml
repomix-output.json

# Firebase Admin SDK private key (should live OUTSIDE public_html on Hostinger)
*firebase-adminsdk*.json
