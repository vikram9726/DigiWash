## 7. Database Schema

> [!WARNING]
> The original PRD was **missing the marketplace tables entirely**. These are documented here for the first time.

### 7.1 Core Tables

```sql
-- users (extended)
CREATE TABLE users (
    id                  INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    name                VARCHAR(200),
    phone               VARCHAR(20) UNIQUE,
    email               VARCHAR(255),
    password_hash       VARCHAR(255),
    dummy_otp           VARCHAR(10),             -- delivery partner PIN
    role                ENUM('customer','delivery','admin') NOT NULL,
    market_id           INT UNSIGNED,
    shop_address        TEXT,
    lat                 DECIMAL(10,7),
    lng                 DECIMAL(10,7),
    is_blocked          TINYINT(1) DEFAULT 0,
    is_online           TINYINT(1) DEFAULT 0,    -- delivery partner only
    current_orders      SMALLINT DEFAULT 0,       -- delivery load counter
    qr_code_hash        VARCHAR(64) UNIQUE,       -- for QR delivery scan
    pay_later_plan      ENUM('NONE','PAY_LATER_4','PAY_LATER_8','PAY_LATER_12') DEFAULT 'NONE',
    pay_later_status    ENUM('locked','pending_approval','approved','declined') DEFAULT 'locked',
    auto_order_frequency ENUM('NONE','MONDAYS') DEFAULT 'NONE',
    auto_order_next_date DATE,
    fcm_token           TEXT,
    created_at          TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    INDEX idx_role_online (role, is_online),
    INDEX idx_market_role (market_id, role)
);

-- orders
CREATE TABLE orders (
    id                  INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    user_id             INT UNSIGNED NOT NULL,
    market_id           INT UNSIGNED,
    delivery_id         INT UNSIGNED,
    status              ENUM('pending','assigned','in_process','out_for_delivery','delivered','cancelled') DEFAULT 'pending',
    total_amount        DECIMAL(10,2) NOT NULL,
    payment_status      ENUM('remaining','completed') DEFAULT 'remaining',
    payment_mode        ENUM('COD','ONLINE','PAY_LATER_4','PAY_LATER_8','PAY_LATER_12'),
    instructions        TEXT,
    lat                 DECIMAL(10,7),
    lng                 DECIMAL(10,7),
    pickup_address      TEXT,
    invoice_id          INT UNSIGNED,
    bypass_photo_url    VARCHAR(500),
    is_quick_pickup     TINYINT(1) DEFAULT 0,
    picked_up_at        DATETIME,
    delivered_at        DATETIME,
    updated_at          TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    created_at          TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    INDEX idx_user_status (user_id, status),
    INDEX idx_delivery_status (delivery_id, status),
    INDEX idx_market_status (market_id, status),
    INDEX idx_created_at (created_at)
);

-- order_items
CREATE TABLE order_items (
    id                  INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    order_id            INT UNSIGNED NOT NULL,
    product_id          INT UNSIGNED,
    product_price_id    INT UNSIGNED,
    product_name        VARCHAR(200),
    size_label          VARCHAR(100),
    price               DECIMAL(10,2),
    quantity            INT DEFAULT 1,
    line_total          DECIMAL(10,2),
    INDEX idx_order (order_id)
);

-- payments
CREATE TABLE payments (
    id                  INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    user_id             INT UNSIGNED NOT NULL,
    order_id            INT UNSIGNED NOT NULL,
    payment_mode        VARCHAR(50),
    status              ENUM('remaining','completed') DEFAULT 'remaining',
    amount              DECIMAL(10,2),
    transaction_id      VARCHAR(255),
    updated_at          TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    created_at          TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    INDEX idx_user_status (user_id, status),
    INDEX idx_order_status (order_id, status)
);
```

### 7.2 Marketplace Tables *(Missing from original PRD)*

```sql
-- marketplace_products
CREATE TABLE marketplace_products (
    id                  INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    name                VARCHAR(200) NOT NULL,
    description         TEXT,
    category            VARCHAR(100),
    price               DECIMAL(10,2),           -- for simple (non-per-meter) products
    image               VARCHAR(500),
    stock               INT DEFAULT 0,
    is_per_meter        TINYINT(1) DEFAULT 0,    -- bedsheets, curtains, etc.
    is_active           TINYINT(1) DEFAULT 1,
    created_at          TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- marketplace_product_widths (for per-meter products)
CREATE TABLE marketplace_product_widths (
    id                  INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    product_id          INT UNSIGNED NOT NULL,
    label               VARCHAR(50),             -- e.g. "4ft", "6ft"
    price_per_meter     DECIMAL(10,2),
    INDEX idx_product (product_id)
);

-- marketplace_orders
CREATE TABLE marketplace_orders (
    id                  INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    user_id             INT UNSIGNED NOT NULL,
    delivery_id         INT UNSIGNED,
    status              ENUM('placed','assigned','picked_up','out_for_delivery','delivered','cancelled') DEFAULT 'placed',
    total_amount        DECIMAL(10,2) NOT NULL,
    payment_type        ENUM('online','credit') NOT NULL,
    payment_status      ENUM('pending','paid','cancelled') DEFAULT 'pending',
    invoice_no          VARCHAR(50),
    picked_up_at        DATETIME,
    delivered_at        DATETIME,
    cancelled_at        DATETIME,
    created_at          TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    INDEX idx_user_payment (user_id, payment_status),
    INDEX idx_status (status)
);

-- marketplace_order_items
CREATE TABLE marketplace_order_items (
    id                  INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    order_id            INT UNSIGNED NOT NULL,
    product_id          INT UNSIGNED,
    quantity            INT DEFAULT 1,
    price               DECIMAL(10,2),           -- per-piece or (price_per_meter × length)
    width_label         VARCHAR(50),
    length_meters       DECIMAL(6,2),
    name                VARCHAR(200),
    size                VARCHAR(100),
    INDEX idx_order (order_id)
);
```

### 7.3 Support & Ancillary Tables

```sql
-- markets
CREATE TABLE markets (
    id          INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    name        VARCHAR(200) NOT NULL,
    created_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- products (laundry catalog)
CREATE TABLE products (
    id          INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    name        VARCHAR(200),
    description TEXT,
    image_url   VARCHAR(500),
    is_active   TINYINT(1) DEFAULT 1,
    created_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- product_prices
CREATE TABLE product_prices (
    id          INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    product_id  INT UNSIGNED NOT NULL,
    size_label  VARCHAR(100),
    price       DECIMAL(10,2),
    unit        VARCHAR(50)
);

-- coupons
CREATE TABLE coupons (
    id              INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    code            VARCHAR(50) UNIQUE,
    discount_type   ENUM('percentage','flat'),
    discount_value  DECIMAL(10,2),
    usage_limit     INT,
    per_user_limit  INT DEFAULT 1,
    min_order_amount DECIMAL(10,2) DEFAULT 0,
    expires_at      DATETIME,
    is_active       TINYINT(1) DEFAULT 1,
    created_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- coupon_usages
CREATE TABLE coupon_usages (
    id              INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    coupon_id       INT UNSIGNED,
    user_id         INT UNSIGNED,
    order_id        INT UNSIGNED,
    discount_amount DECIMAL(10,2),
    used_at         TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- notifications
CREATE TABLE notifications (
    id          INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    user_id     INT UNSIGNED NOT NULL,
    title       VARCHAR(200),
    message     TEXT,
    is_read     TINYINT(1) DEFAULT 0,
    created_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    INDEX idx_user_read (user_id, is_read)
);

-- returns
CREATE TABLE returns (
    id              INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    order_id        INT UNSIGNED,
    user_id         INT UNSIGNED,
    reason          TEXT,
    photo_url       VARCHAR(500),
    admin_status    ENUM('pending','approved','declined') DEFAULT 'pending',
    created_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- staff_requests
CREATE TABLE staff_requests (
    id              INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    user_id         INT UNSIGNED NOT NULL,
    message         TEXT,
    admin_note      TEXT,
    delivery_id     INT UNSIGNED,               -- assigned delivery rep (optional)
    status          ENUM('pending','seen','resolved') DEFAULT 'pending',
    created_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- otp_attempts (MISSING — add for rate limiting)
CREATE TABLE otp_attempts (
    id          INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    phone       VARCHAR(20),
    created_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    INDEX idx_phone_time (phone, created_at)
);

-- settings
CREATE TABLE settings (
    id      INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    `key`   VARCHAR(100) UNIQUE,
    `value` TEXT
);
```

